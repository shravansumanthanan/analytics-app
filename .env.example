# Docker Compose Environment Variables
# Copy this file to .env and update with your production values

# Admin password for dashboard access
ADMIN_PASSWORD=your-secure-password-here

# Allowed origins for CORS (comma-separated)
# For production, replace with your actual domain(s)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Optional: MongoDB URI (defaults to local MongoDB in docker-compose)
# For production, consider using MongoDB Atlas
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/analytics_db
