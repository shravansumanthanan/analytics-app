# Copy this file to .env and fill in your values.
# Never commit .env to version control.

PORT=4000

# MongoDB Atlas connection string (or local for development)
MONGODB_URI=mongodb://localhost:27017/analyticsos

NODE_ENV=development

# Comma-separated list of allowed origins for the dashboard API
# In production, set this to your Vercel frontend URL
ALLOWED_ORIGINS=http://localhost:5173

# Strong random password for the analytics dashboard and API key.
# Generate one with: openssl rand -base64 32
ADMIN_PASSWORD=change_me_in_production

# Set to true to require X-API-Key header on POST /api/events (tracker ingestion).
# When false (default), ingestion is open — suitable for local development.
# Set to true in production to prevent unauthorized data writes.
REQUIRE_API_KEY=false
