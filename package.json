{
  "name": "analytics-os",
  "version": "1.0.0",
  "private": true,
  "description": "Analytics OS - Telemetry Platform",
  "workspaces": [
    "backend",
    "frontend",
    "tests/e2e"
  ],
  "scripts": {
    "install:all": "npm install --workspaces",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:demo": "node backend/demo/server.js",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:demo\"",
    "build": "npm run build --workspaces --if-present",
    "test": "npm test --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
