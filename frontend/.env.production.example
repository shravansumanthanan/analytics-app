# Frontend Production Environment Variables
# Copy this file to .env.production and update with your backend URL

# Full URL to your backend API (including /api path)
# Examples:
# - Railway: https://analytics-backend-xxx.railway.app/api
# - Render: https://analytics-backend.onrender.com/api
# - Custom domain: https://api.yourdomain.com/api
VITE_API_URL=https://your-backend-url.com/api
